APP_NAME=Tabylga API
APP_TIMEZONE=Asia/Bishkek
POSTGRES_DB=tabylga
POSTGRES_USER=tabylga
POSTGRES_PASSWORD=tabylga
DATABASE_URL=postgresql://tabylga:tabylga@db:5432/tabylga
OPEN_ROUTE_SERVICE_API_KEY=replace-with-your-openrouteservice-key
ORS_BASE_URL=https://api.openrouteservice.org/v2
CHECK_IN_RADIUS_METERS=250
ALLOWED_ORIGINS=*
AUTO_INIT_DB=true
ENABLE_DB_SEED=true
CREATE_POSTGIS_EXTENSION=false
DB_CONNECT_RETRIES=12
DB_CONNECT_RETRY_DELAY_SECONDS=1.5
